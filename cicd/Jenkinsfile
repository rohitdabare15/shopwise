pipeline {
    agent any

    environment {
        AWS_REGION   = 'us-east-1'
        CLUSTER_NAME = 'shopwise-dev'
        NAMESPACE    = 'shopwise'
        IMAGE_TAG    = "build-${env.BUILD_NUMBER}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        stage('Setup') {
            steps {
                script {
                    env.AWS_ACCOUNT_ID = sh(
                        script: 'aws sts get-caller-identity --query Account --output text',
                        returnStdout: true
                    ).trim()
                    env.ECR_REGISTRY = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com"
                    echo "Account: ${env.AWS_ACCOUNT_ID}"
                    echo "Registry: ${env.ECR_REGISTRY}"
                }
            }
        }

        stage('Build Images') {
            parallel {
                stage('Build Backend') {
                    steps {
                        sh """
                            docker build \
                              -t shopwise-backend:${IMAGE_TAG} \
                              -t shopwise-backend:latest \
                              ./applications/backend
                        """
                    }
                }
                stage('Build Frontend') {
                    steps {
                        sh """
                            docker build \
                              -t shopwise-frontend:${IMAGE_TAG} \
                              -t shopwise-frontend:latest \
                              ./applications/frontend
                        """
                    }
                }
            }
        }

        stage('Push to ECR') {
            steps {
                sh """
                    aws ecr get-login-password --region ${AWS_REGION} | \
                      docker login --username AWS \
                      --password-stdin ${ECR_REGISTRY}

                    docker tag shopwise-backend:${IMAGE_TAG} \
                      ${ECR_REGISTRY}/shopwise/backend:${IMAGE_TAG}
                    docker tag shopwise-backend:latest \
                      ${ECR_REGISTRY}/shopwise/backend:latest
                    docker push ${ECR_REGISTRY}/shopwise/backend:${IMAGE_TAG}
                    docker push ${ECR_REGISTRY}/shopwise/backend:latest

                    docker tag shopwise-frontend:${IMAGE_TAG} \
                      ${ECR_REGISTRY}/shopwise/frontend:${IMAGE_TAG}
                    docker tag shopwise-frontend:latest \
                      ${ECR_REGISTRY}/shopwise/frontend:latest
                    docker push ${ECR_REGISTRY}/shopwise/frontend:${IMAGE_TAG}
                    docker push ${ECR_REGISTRY}/shopwise/frontend:latest
                """
            }
        }

        stage('Deploy to EKS') {
            steps {
                sh """
                    aws eks update-kubeconfig \
                      --region ${AWS_REGION} \
                      --name ${CLUSTER_NAME}

                    kubectl set image deployment/backend \
                      backend=${ECR_REGISTRY}/shopwise/backend:${IMAGE_TAG} \
                      -n ${NAMESPACE}

                    kubectl set image deployment/frontend \
                      frontend=${ECR_REGISTRY}/shopwise/frontend:${IMAGE_TAG} \
                      -n ${NAMESPACE}

                    kubectl rollout status deployment/backend \
                      -n ${NAMESPACE} --timeout=300s

                    kubectl rollout status deployment/frontend \
                      -n ${NAMESPACE} --timeout=300s

                    kubectl get pods -n ${NAMESPACE}
                """
            }
        }

        stage('Verify') {
            steps {
                sh """
                    ALB_URL=\$(kubectl get ingress shopwise-ingress \
                      -n ${NAMESPACE} \
                      -o jsonpath='{.status.loadBalancer.ingress[0].hostname}')

                    echo "Testing: http://\$ALB_URL"
                    sleep 15

                    for i in 1 2 3 4 5; do
                      STATUS=\$(curl -s -o /dev/null -w "%{http_code}" \
                        http://\$ALB_URL/health || echo "000")
                      echo "Attempt \$i: HTTP \$STATUS"
                      if [ "\$STATUS" = "200" ]; then
                        echo "Deployment verified"
                        exit 0
                      fi
                      sleep 10
                    done
                    exit 1
                """
            }
        }
    }

    post {
        success {
            echo "Build ${env.IMAGE_TAG} deployed to ${CLUSTER_NAME}"
        }
        failure {
            echo "Pipeline failed. Check console output above."
        }
        always {
            sh """
                docker rmi shopwise-backend:${IMAGE_TAG} || true
                docker rmi shopwise-frontend:${IMAGE_TAG} || true
            """
            cleanWs()
        }
    }
}

